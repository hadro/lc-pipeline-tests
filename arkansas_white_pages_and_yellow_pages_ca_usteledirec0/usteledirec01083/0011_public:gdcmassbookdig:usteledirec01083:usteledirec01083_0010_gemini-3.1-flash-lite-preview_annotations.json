    {
      "type": "Annotation",
      "motivation": "supplementing",
      "body": {
        "type": "TextualBody",
        "value": "The Telephone Business Office for the Caraway and Monette exchanges is located in the Monette, Arkansas telephone central office building. The hours of operation for this office are from 8:00 a.m. until 12:00 noon, and 1:00 p.m. until 5:00 p.m., daily, Monday through Friday. Payments may be made at the Business Office, by mail, or by using the convenient Caraway or Monette depositories.",
        "format": "text/plain",
        "language": "en"
      },
      "target": "https://www.loc.gov/item/usteledirec01083/canvas/11#xywh=1411,4250,2590,82"
    },
    {
      "type": "Annotation",
      "motivation": "supplementing",
      "body": {
        "type": "TextualBody",
        "value": "You are always welcome to stop in and discuss your telephone business matters or to inquire about the many additional telephone facilities which can make your service more useful and convenient.",
