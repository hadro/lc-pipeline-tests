      "body": {
        "type": "TextualBody",
        "value": "til 12:00 noon, and 1:00 p.m. until 5:00 p.m., daily, Monday through Friday. Payments may be made at",
        "format": "text/plain",
        "language": "en"
      },
      "target": "https://www.loc.gov/item/usteledirec01083/canvas/11#xywh=1411,4307,2590,83"
